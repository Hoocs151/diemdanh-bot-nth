# ============================================
# BANG CHIEN BOT - ENVIRONMENT CONFIGURATION
# ============================================
# Copy file nay thanh .env va dien thong tin
# Chi thay doi gia tri phia sau dau =
# ============================================

# ---- Discord Bot (BAT BUOC) ----
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_OWNER_ID=

# ---- Phan quyen (phan cach bang dau phay) ----
# ADMIN: co quyen tao, khoa, chot, xuat, datlai, sua, xoa phien
ADMIN_ROLE_IDS=
# OFFICER: co quyen tao, khoa, chot, xuat, datlai (khong co sua/xoa)
OFFICER_ROLE_IDS=

# ---- Database ----
DB_PATH=./data/botdiemdanh.db

# ---- Logging ----
LOG_LEVEL=info
TIMEZONE=Asia/Ho_Chi_Minh

# ---- Hanh vi bot ----
# So phut truoc khi tu dong khoa phien (0 = tat)
AUTO_LOCK_MINUTES=0
# So nguoi toi da moi phai (0 = khong gioi han)
MAX_PER_FACTION=0
# So giay giua 2 thao tac cung user (chong spam)
DEBOUNCE_MS=1000
# So giay de reply bi xoa
EPHEMERAL_SECONDS=5

# ---- Notification ----
DEFAULT_NOTIFY_CHANNEL_ID=

# ---- Backup tu dong ----
AUTO_BACKUP_ENABLED=false
BACKUP_CRON_SCHEDULE=0 3 * * *
BACKUP_RETENTION_COUNT=7
BACKUP_DIR=./backups

# ---- Rate limit slash commands ----
SLASH_RATE_LIMIT_COUNT=5
SLASH_RATE_LIMIT_WINDOW_MS=30000

# ---- Google Sheets Export (TUY CHON) ----
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1
